
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  name              String?
  businessName      String?
  kybStatus         String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  wallets       Wallet[]
  apiKeys       ApiKey[]
  transactions  Transaction[]
  settlements   Settlement[]
  
  investments   Investment[]
  kycRecord     KycRecord?
  orders        Order[]
}

model Wallet {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  currency      String    // USD, USDC, NGN, GHS
  balance       Float     @default(0.0)
  address       String?   // Crypto address if applicable
  safeAddress   String?   // Safe wallet address for custody
  type          String    // FIAT, CRYPTO, SAFE_MULTISIG
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Transaction {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  type          String    // PAYMENT, SETTLEMENT, CONVERSION
  amount        Float     // Fiat amount
  currency      String    // Fiat currency (NGN, GHS)
  usdcAmount    Float?    // Equivalent USDC
  rate          Float?    // Conversion rate
  status        String    // PENDING, COMPLETED, FAILED
  reference     String?   @unique // Paystack or Payaza reference
  provider      String    @default("PAYSTACK") // PAYSTACK, PAYAZA
  createdAt     DateTime  @default(now())
}

model Settlement {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Float     // USDC amount
  status        String    // PENDING, COMPLETED, FAILED
  txHash        String?   // Blockchain tx hash
  createdAt     DateTime  @default(now())
}

model ApiKey {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  key           String    @unique
  secret        String
  type          String    // SANDBOX, PRODUCTION
  createdAt     DateTime  @default(now())
  isActive      Boolean   @default(true)
}

model Asset {
  id            String    @id @default(uuid())
  name          String
  description   String
  type          String    // REAL_ESTATE, EQUITY, FUND
  totalValue    Float
  tokenPrice    Float
  totalTokens   Int
  availableTokens Int
  location      String?
  yield         Float?    // Annual yield percentage
  status        String    @default("ACTIVE") // ACTIVE, FUNDED, CLOSED
  imageUrl      String?
  tokenAddress  String?   // thirdweb contract address
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  investments   Investment[]
  orders        Order[]
}

model Investment {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id])
  tokens        Int
  amount        Float     // Total invested amount
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model KycRecord {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  status        String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  idType        String?
  idNumber      String?
  documentUrl   String?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id])
  type          String    // BUY, SELL
  price         Float
  quantity      Int
  status        String    @default("OPEN") // OPEN, FILLED, CANCELLED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
