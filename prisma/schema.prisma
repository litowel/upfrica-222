
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  kycStatus     String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  wallets       Wallet[]
  apiKeys       ApiKey[]
  transactions  Transaction[]
}

model Wallet {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  currency      String    // USD, USDC, BTC, ETH
  balance       Float     @default(0.0)
  address       String?   // Crypto address if applicable
  type          String    // FIAT, CRYPTO, SAFE_MULTISIG
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Transaction {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  type          String    // DEPOSIT, WITHDRAWAL, TRANSFER, TRADE, INVEST
  amount        Float
  currency      String
  status        String    // PENDING, COMPLETED, FAILED
  reference     String?   // External reference (Paystack, Transak, etc.)
  createdAt     DateTime  @default(now())
}

model ApiKey {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  key           String    @unique
  secret        String
  type          String    // SANDBOX, PRODUCTION
  createdAt     DateTime  @default(now())
  isActive      Boolean   @default(true)
}
